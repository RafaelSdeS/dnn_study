{
  "experiment": {
    "name": "large_scale",
    "models": [
      "alexnet_fire"
    ],
    "seed": 42,
    "stages": [
      "fp32",
      "qat",
      "int8"
    ],
    "data": {
      "batch_size": 64,
      "num_workers": 4,
      "pin_memory": true,
      "train_val_split": 0.9
    },
    "training": {
      "epochs": 1000,
      "lr": 0.0003,
      "weight_decay": 0.0005,
      "label_smoothing": 0.1,
      "grad_clip_norm": null,
      "use_amp": true,
      "early_stopping_patience": 20
    },
    "qat": {
      "epochs": 100,
      "lr": 1e-05,
      "weight_decay": 0.0005,
      "freeze_bn_epoch": 3,
      "disable_observer_epoch": 5
    }
  },
  "runtime": {
    "name": "pcad",
    "root": "outputs/pcad",
    "dataset_root": "${PCAD_DATASET_ROOT}",
    "device": "cuda",
    "conda_env": "alexnet_rafael",
    "wandb": true,
    "wandb_mode": "offline",
    "tensorboard": true,
    "distributed": false,
    "devices": 1,
    "launcher": "single",
    "use_kagglehub_fallback": true,
    "persistent_workers": true,
    "benchmark_warmup": 100,
    "quantized_engine": "fbgemm"
  },
  "data": {
    "dataset_path": "/home/users/rsdsouza/.cache/kagglehub/datasets/akash2sharma/tiny-imagenet/versions/1/tiny-imagenet-200/train",
    "img_size": 64,
    "num_classes": 200,
    "batch_size": 64,
    "num_workers": 4,
    "pin_memory": true,
    "train_val_split": 0.9,
    "seed": 42
  },
  "training": {
    "epochs": 1000,
    "lr": 0.001,
    "weight_decay": 0.0005,
    "label_smoothing": 0.1,
    "grad_clip_norm": null,
    "use_amp": true,
    "early_stopping_patience": 20
  },
  "qat": {
    "epochs": 100,
    "lr": 1e-05,
    "weight_decay": 0.0005,
    "freeze_bn_epoch": 3,
    "disable_observer_epoch": 5
  },
  "selected_model": "alexnet_fire",
  "stage_list": [
    "fp32",
    "qat",
    "int8"
  ]
}